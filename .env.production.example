NODE_ENV=production
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME
AI_TRANSLATE_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_TRANSLATE_MODEL=gpt-4.1-mini
ADMIN_SESSION_SECRET=strong_random_admin_session_secret
ADMIN_SEED_EMAIL=admin@your-domain.com
ADMIN_SEED_PASSWORD=strong_random_admin_seed_password
MARIADB_ROOT_PASSWORD=unused_in_managed_db
MARIADB_DATABASE=DATABASE_NAME
MARIADB_USER=USER
MARIADB_PASSWORD=PASSWORD
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_DEFAULT_LOCALE=tr
NEXT_PUBLIC_SUPPORTED_LOCALES=tr,en
